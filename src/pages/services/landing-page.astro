---
import Layout from '../../layouts/Layout.astro';
---
<Layout description="Landing pages optimisées IA et conversion – +40% de leads en 14 jours ou remboursé" title="Landing page IA - Conversion garantie">
  <main>
    <section class="container">
      <h1>Landing pages qui convertissent visiteurs… et agents IA</h1>
      <h2>+40% de leads en 14 jours ou remboursé</h2>

      <!-- Section Ce que vous obtenez -->
      <div class="grid" style="margin-top: 2rem;">
        <div>
          <h3>Ce que vous obtenez</h3>
          <ul>
            <li>✅ Structure sémantique H1→H6 optimisée pour les agents IA</li>
            <li>✅ Données structurées JSON-LD (FAQ, Product, Review) prêtes à l'emploi</li>
            <li>✅ Fichier llms.txt intégré automatiquement</li>
            <li>✅ Performance Lighthouse > 95/100 (cache serveur, CSS critique)</li>
            <li>✅ Formulaire "agent-actionnable" (champs simples, envoi direct)</li>
          </ul>
        </div>
        <div>
          <!-- éventuelle illustration, laisser vide ou ajouter une icône -->
        </div>
      </div>

      <!-- Témoignages (placeholders) -->
      <div class="grid" style="margin: 3rem 0;">
        <div class="testimonial">
          <p>"Notre lead a augmenté de 58% en 3 semaines. La page est ultra-rapide et bien référencée."</p>
          <strong>Sophie Martin</strong>, Directrice Marketing, Agence Lumière
        </div>
        <div class="testimonial">
          <p>"Grâce à l'optimisation IA, nous sommes apparus dans les réponses de ChatGPT. Un game changer."</p>
          <strong>Thomas Dubois</strong>, Fondateur, TechStart
        </div>
      </div>

      <!-- Lead magnet -->
      <div style="background: #f5f5f5; padding: 2rem; text-align: center; border-radius: 1rem;">
        <h3>Checklist gratuite : 15 points pour qu'une landing page soit rankée par ChatGPT & Google</h3>
        <a href="#" class="button">Télécharger la checklist</a>
        <p style="font-size: 0.8rem;">PDF instantané, sans inscription (fichier à venir)</p>
      </div>

      <!-- Garantie -->
      <div style="margin: 2rem 0; text-align: center;">
        <p><strong>🎯 100% satisfait ou remboursé pendant 30 jours</strong> – sans aucune condition.</p>
      </div>

      <!-- Tableau comparatif -->
      <h3>Landing page classique vs optimisée IA</h3>
      <table style="width:100%; border-collapse: collapse;">
        <thead>
          <tr style="background:#eee;">
            <th style="padding:0.75rem;">Critère</th>
            <th style="padding:0.75rem;">Classique</th>
            <th style="padding:0.75rem;">Optimisée IA (GEO)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td style="padding:0.5rem;">Vitesse (Lighthouse)</td><td>45-65</td><td><strong>95+</strong></td></tr>
          <tr><td style="padding:0.5rem;">Visibilité dans ChatGPT / agents IA</td><td>Faible</td><td><strong>Élevée (llms.txt, JSON-LD)</strong></td></tr>
          <tr><td style="padding:0.5rem;">Taux de conversion leads</td><td>1-2%</td><td><strong>3-5%</strong></td></tr>
          <tr><td style="padding:0.5rem;">Prix (mise en place)</td><td>1 500€ – 3 000€</td><td><strong>1 200€ (offre early)</strong></td></tr>
        </tbody>
      </table>

      <!-- FAQ avec JSON-LD -->
      <div style="margin: 3rem 0;">
        <h3>Questions fréquentes</h3>
        <div itemscope itemtype="https://schema.org/FAQPage">
          <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h4 itemprop="name">Cette landing page sera-t-elle visible par ChatGPT et les agents IA ?</h4>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <div itemprop="text">Oui, nous intégrons les bonnes pratiques GEO : données structurées, fichier llms.txt, cache adapté, et balises sémantiques. Votre page sera lue et interprétée par les principaux agents d'IA.</div>
            </div>
          </div>
          <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h4 itemprop="name">Quel est le délai de mise en ligne ?</h4>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <div itemprop="text">En moyenne 5 à 7 jours ouvrés, y compris les tests de performance et l'intégration des données structurées.</div>
            </div>
          </div>
          <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h4 itemprop="name">Puis-je intégrer cette landing page à mon site existant ?</h4>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <div itemprop="text">Absolument. Nous fournissons un code prêt à l'emploi (HTML/CSS/JS) que vous pouvez déposer sur n'importe quel hébergement ou CMS.</div>
            </div>
          </div>
        </div>
      </div>
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Cette landing page sera-t-elle visible par ChatGPT et les agents IA ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Oui, nous intégrons les bonnes pratiques GEO : données structurées, fichier llms.txt, cache adapté, et balises sémantiques. Votre page sera lue et interprétée par les principaux agents d'IA."
            }
          },
          {
            "@type": "Question",
            "name": "Quel est le délai de mise en ligne ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "En moyenne 5 à 7 jours ouvrés, y compris les tests de performance et l'intégration des données structurées."
            }
          },
          {
            "@type": "Question",
            "name": "Puis-je intégrer cette landing page à mon site existant ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolument. Nous fournissons un code prêt à l'emploi (HTML/CSS/JS) que vous pouvez déposer sur n'importe quel hébergement ou CMS."
            }
          }
        ]
      }
      </script>

      <!-- Formulaire de contact -->
      <div id="formulaire" style="margin: 2rem 0; padding: 1rem; border: 1px solid #ddd;">
        <h3>Demander votre landing page IA</h3>
        <form id="landing-form">
          <input type="text" name="name" placeholder="Nom complet" required>
          <input type="email" name="email" placeholder="Email professionnel" required>
          <input type="tel" name="phone" placeholder="Téléphone (optionnel)">
          <textarea name="message" placeholder="Dites-nous en plus sur votre projet..."></textarea>
          <button type="submit" class="button">Obtenir ma landing page</button>
          <div id="form-message"></div>
        </form>
      </div>

      <!-- Footer interne -->
      <footer style="margin-top: 3rem; font-size: 0.8rem; text-align: center;">
        <p>Garantie satisfait ou remboursé 30 jours – <a href="/mentions-legales">Mentions légales</a></p>
      </footer>
    </section>
  </main>
</Layout>

<script>
  const form = document.getElementById('landing-form') as HTMLFormElement | null;
  const messageDiv = document.getElementById('form-message') as HTMLElement | null;

  if (form && messageDiv) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        phone: formData.get('phone'),
        message: formData.get('message')
      };

      messageDiv.innerHTML = 'Envoi en cours...';
      
      try {
        const res = await fetch('https://admin.energon.cloud/api/collections/Contacts/records', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (res.ok) {
          messageDiv.innerHTML = '<span style="color:green;">✅ Message envoyé ! Nous vous recontacterons rapidement.</span>';
          form.reset();
        } else {
          const err = await res.text();
          messageDiv.innerHTML = `<span style="color:red;">❌ Erreur : ${err}. Merci de réessayer ou nous contacter directement.</span>`;
        }
      } catch (error) {
        messageDiv.innerHTML = '<span style="color:red;">❌ Problème réseau. Veuillez réessayer.</span>';
      }
    });
  }
</script>
