---
import Layout from '../../layouts/Layout.astro';
---
<Layout description="Landing pages optimisées IA et conversion – Score PageSpeed Insights > 90 et conformité IA garantis" title="Landing page IA - Conversion garantie">
  <main>
    <!-- Header minimaliste -->
    <div style="text-align: center; padding: 2rem 0;"><a href="/"><img src="/images/logo.svg" alt="Energon" width="150" /></a></div>

    <section class="container">
      <section class="lp-section">
        <h1>Landing pages qui convertissent visiteurs… et agents IA</h1>
        <h2>Qualité technique garantie : Score PageSpeed Insights &gt; 90 et conformité IA</h2>
      </section>

      <!-- Section Ce que vous obtenez -->
      <section class="lp-section">
        <div class="grid" style="margin-top: 2rem;">
          <div>
            <h3>Ce que vous obtenez</h3>
            <ul>
              <li>✅ Structure sémantique H1→H6 optimisée pour les agents IA</li>
              <li>✅ Données structurées JSON-LD (FAQ, Product, Review) prêtes à l'emploi</li>
              <li>✅ Fichier llms.txt intégré automatiquement</li>
              <li>✅ Performance PageSpeed Insights &gt; 90/100 (cache serveur, CSS critique)</li>
              <li>✅ Formulaire "agent-actionnable" (champs simples, envoi direct)</li>
            </ul>
          </div>
          <div>
            <!-- éventuelle illustration, laisser vide ou ajouter une icône -->
          </div>
        </div>
      </section>

      <!-- Témoignages -->
      <section class="lp-section">
        <div class="grid" style="margin: 3rem 0;">
          <div class="testimonial lp-card">
            <p>"Notre trafic qualifié a significativement augmenté en quelques semaines. La page est ultra-rapide et bien référencée."</p>
            <strong>Gérant d'une PME locale</strong>
          </div>
          <div class="testimonial lp-card">
            <p>"Grâce à l'optimisation IA, nous sommes apparus dans les réponses de ChatGPT et Gemini. Un game changer."</p>
            <strong>Fondateur d'une startup tech</strong>
          </div>
        </div>
      </section>

      <!-- Lead magnet -->
      <section class="lp-section">
        <div class="lp-card" style="text-align: center;">
          <h3>Checklist gratuite : 15 points pour qu'une landing page soit rankée par ChatGPT &amp; Google</h3>
          <a href="#" class="button" style="margin-top: 1rem; display: inline-block;">Télécharger la checklist</a>
          <p class="lp-text-highlight" style="margin-top: 0.75rem;">PDF instantané, sans inscription (fichier à venir)</p>
        </div>
      </section>

      <!-- Garantie -->
      <section class="lp-section" style="text-align: center;">
        <p><strong>🎯 Qualité technique garantie : Score PageSpeed Insights &gt; 90 et conformité IA</strong></p>
      </section>

      <!-- Tableau comparatif -->
      <section class="lp-section">
        <h3>Landing page classique vs optimisée IA</h3>
        <table class="lp-table">
          <thead>
            <tr>
              <th>Critère</th>
              <th>Classique</th>
              <th>Optimisée IA (GEO)</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Vitesse (PageSpeed Insights)</td><td>45-65</td><td><strong>90+</strong></td></tr>
            <tr><td>Visibilité dans les agents IA</td><td>Faible</td><td><strong>Élevée (ChatGPT, ClaudeAI, Gemini, JSON-LD)</strong></td></tr>
            <tr><td>Taux de conversion leads</td><td>1-2%</td><td><strong>3-5%</strong></td></tr>
          </tbody>
        </table>
      </section>

      <!-- FAQ avec JSON-LD -->
      <section class="lp-section">
        <h3>Questions fréquentes</h3>
        <div itemscope itemtype="https://schema.org/FAQPage">
          <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h4 itemprop="name">Cette landing page sera-t-elle visible par ChatGPT et les agents IA ?</h4>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <div itemprop="text">Oui, nous intégrons les bonnes pratiques GEO : données structurées, fichier llms.txt, cache adapté, et balises sémantiques. Votre page sera lue et interprétée par les principaux agents d'IA.</div>
            </div>
          </div>
          <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h4 itemprop="name">Quel est le délai de mise en ligne ?</h4>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <div itemprop="text">En moyenne 5 à 7 jours ouvrés, y compris les tests de performance et l'intégration des données structurées.</div>
            </div>
          </div>
          <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h4 itemprop="name">Puis-je intégrer cette landing page à mon site existant ?</h4>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <div itemprop="text">Absolument. Nous fournissons un code prêt à l'emploi (HTML/CSS/JS) que vous pouvez déposer sur n'importe quel hébergement ou CMS.</div>
            </div>
          </div>
        </div>
      </section>
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Cette landing page sera-t-elle visible par ChatGPT et les agents IA ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Oui, nous intégrons les bonnes pratiques GEO : données structurées, fichier llms.txt, cache adapté, et balises sémantiques. Votre page sera lue et interprétée par les principaux agents d'IA."
            }
          },
          {
            "@type": "Question",
            "name": "Quel est le délai de mise en ligne ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "En moyenne 5 à 7 jours ouvrés, y compris les tests de performance et l'intégration des données structurées."
            }
          },
          {
            "@type": "Question",
            "name": "Puis-je intégrer cette landing page à mon site existant ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolument. Nous fournissons un code prêt à l'emploi (HTML/CSS/JS) que vous pouvez déposer sur n'importe quel hébergement ou CMS."
            }
          }
        ]
      }
      </script>

      <!-- Formulaire de contact -->
      <section class="lp-section">
        <div id="formulaire" class="lp-card">
          <h3>Demander votre landing page IA</h3>
          <form id="landing-form">
            <div class="lp-form-group">
              <input type="text" name="name" placeholder="Nom complet" required class="lp-input">
            </div>
            <div class="lp-form-group">
              <input type="email" name="email" placeholder="Email professionnel" required class="lp-input">
            </div>
            <div class="lp-form-group">
              <input type="tel" name="phone" placeholder="Téléphone" required class="lp-input">
            </div>
            <div class="lp-form-group">
              <textarea name="message" placeholder="Dites-nous en plus sur votre projet..." required class="lp-input" rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--large" style="width: 100%;">Obtenir ma landing page</button>
            <div id="form-message" style="margin-top: 1rem;"></div>
          </form>
        </div>
      </section>

      <!-- Footer interne -->
      <footer style="margin-top: 3rem; font-size: 0.8rem; text-align: center;">
        <p>Qualité technique garantie – <a href="/mentions-legales">Mentions légales</a></p>
      </footer>
    </section>
  </main>
</Layout>

<style>
  .lp-section { margin-bottom: 5rem; }
  .lp-card { background: #1a1a1a; padding: 2rem; border-radius: 12px; border: 1px solid #333; }
  .lp-table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
  .lp-table th, .lp-table td { padding: 1rem; text-align: left; border-bottom: 1px solid #333; color: #fff; }
  .lp-table th { background: #222; font-weight: bold; }
  .lp-form-group { margin-bottom: 1.5rem; }
  .lp-input { width: 100%; padding: 1rem; background: #111; border: 1px solid #444; color: #fff; border-radius: 8px; font-family: inherit; }
  .lp-input:focus { border-color: #fff; outline: none; }
  .lp-text-highlight { color: #aaa; font-size: 0.9rem; }
</style>

<script>
  const form = document.getElementById('landing-form') as HTMLFormElement | null;
  const messageDiv = document.getElementById('form-message') as HTMLElement | null;

  if (form && messageDiv) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        phone: formData.get('phone'),
        message: formData.get('message')
      };

      messageDiv.innerHTML = 'Envoi en cours...';
      
      try {
        const res = await fetch('https://admin.energon.cloud/api/collections/Contacts/records', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (res.ok) {
          messageDiv.innerHTML = '<span style="color:green;">✅ Message envoyé ! Nous vous recontacterons rapidement.</span>';
          form.reset();
        } else {
          const err = await res.text();
          messageDiv.innerHTML = `<span style="color:red;">❌ Erreur : ${err}. Merci de réessayer ou nous contacter directement.</span>`;
        }
      } catch (error) {
        messageDiv.innerHTML = '<span style="color:red;">❌ Problème réseau. Veuillez réessayer.</span>';
      }
    });
  }
</script>
