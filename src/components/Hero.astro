---
import siteContent from '../data/siteContent.json';
const { hero } = siteContent;
---

<section class="hero" id="hero" aria-labelledby="hero-heading">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__gradient"></div>
    <div class="hero__grid"></div>
  </div>

  <div class="container hero__content">
    <div class="hero__text">
      {hero.badge && (
        <div class="hero__badge animate-fade-in-up">
          <span class="hero__badge-dot" aria-hidden="true"></span>
          {hero.badge}
        </div>
      )}
      <h1 id="hero-heading" class="hero__title animate-fade-in-up">
        Votre <span class="gradient-text">Croissance Digitale, Automatisée</span>
      </h1>
      <p class="hero__subtitle animate-fade-in-up animate-delay-1">
        {hero.subheadline}
      </p>
      <div class="hero__ctas animate-fade-in-up animate-delay-2">
        <a href={hero.ctaPrimary.href} class="btn btn--primary btn--large">
          {hero.ctaPrimary.text}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={hero.ctaSecondary.href} class="btn btn--secondary btn--large">
          {hero.ctaSecondary.text}
        </a>
      </div>

      {hero.stats && (
        <div class="hero__stats animate-fade-in-up animate-delay-3">
          {hero.stats.map((stat) => (
            <div class="hero__stat">
              <span class="hero__stat-value">{stat.value}</span>
              <span class="hero__stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
