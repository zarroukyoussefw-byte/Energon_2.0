---
import siteContent from '../data/siteContent.json';
const { portfolio } = siteContent;

const categories = ['Tous', ...new Set(portfolio.items.map(item => item.category))];

/* Accent color per category */
const accentMap: Record<string, string> = {
  'Site Web': '#a855f7',
  'Landing Page': '#a855f7',
  'Application Web': '#06b6d4',
  'Automatisation IA': '#7c3aed',
  'Service IA': '#a855f7',
};
---

<section class="portfolio section" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="container">
    <div class="portfolio__header">
      <span class="portfolio__label">// Réalisations</span>
      <h2 id="portfolio-heading" class="portfolio__title">
        Des résultats, pas des <span class="portfolio__title-accent">promesses</span>
      </h2>
    </div>

    <div class="portfolio__filters" role="tablist" aria-label="Filtrer les réalisations par catégorie">
      {categories.map((cat, i) => (
        <button
          class={`portfolio__filter ${i === 0 ? 'is-active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-filter={cat === 'Tous' ? 'all' : cat}
          type="button"
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="portfolio__grid" role="list">
      {portfolio.items.map((item, idx) => {
        const accent = accentMap[item.category] || '#a855f7';
        return (
          <article
            class="portfolio__card"
            data-category={item.category}
            role="listitem"
            style={`--card-accent: ${accent}; --card-delay: ${idx * 0.08}s;`}
          >
            <div class="portfolio__metric-zone">
              <span class="portfolio__badge">{item.category}</span>
              <div class="portfolio__metric">
                <span class="portfolio__metric-value">{item.metric}</span>
                <span class="portfolio__metric-label">{item.metricLabel}</span>
              </div>
            </div>
            <div class="portfolio__info">
              <h3 class="portfolio__card-title">{item.title}</h3>
              <p class="portfolio__card-desc">{item.description}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Header */
  .portfolio__header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .portfolio__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: #a855f7;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }

  .portfolio__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    color: var(--color-text);
  }

  .portfolio__title-accent {
    background: linear-gradient(135deg, #a855f7, #06b6d4);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Filters */
  .portfolio__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-bottom: var(--space-8);
  }

  .portfolio__filter {
    padding: 6px 14px;
    background: transparent;
    border: 1px solid rgba(168, 85, 247, 0.1);
    border-radius: 7px;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .portfolio__filter:hover {
    border-color: rgba(168, 85, 247, 0.3);
    color: #a855f7;
  }

  .portfolio__filter.is-active {
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    border-color: transparent;
    color: #fff;
  }

  /* Grid */
  .portfolio__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 560px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .portfolio__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .portfolio__card {
    border-radius: 14px;
    border: 1px solid rgba(168, 85, 247, 0.1);
    background: #0e0e1888;
    overflow: hidden;
    transition: all var(--transition-base);
    animation: cardIn 0.5s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  .portfolio__card.is-hidden {
    display: none;
  }

  .portfolio__card:hover {
    border-color: rgba(168, 85, 247, 0.25);
    background: #141422cc;
    transform: translateY(-3px);
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Metric zone (top) */
  .portfolio__metric-zone {
    position: relative;
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    background: linear-gradient(135deg, color-mix(in srgb, var(--card-accent) 9%, transparent), var(--color-bg-elevated));
  }

  .portfolio__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 13%, transparent);
    border-radius: 4px;
    padding: 3px 7px;
    line-height: 1;
  }

  .portfolio__metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .portfolio__metric-value {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: var(--weight-bold);
    color: var(--card-accent);
    line-height: 1;
  }

  .portfolio__metric-label {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }

  /* Info zone (bottom) */
  .portfolio__info {
    padding: 16px 18px 20px;
  }

  .portfolio__card-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .portfolio__card-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
</style>

<script>
  const filters = document.querySelectorAll('.portfolio__filter');
  const cards = document.querySelectorAll('.portfolio__card');

  filters.forEach(filter => {
    filter.addEventListener('click', () => {
      filters.forEach(f => {
        f.classList.remove('is-active');
        f.setAttribute('aria-selected', 'false');
      });
      filter.classList.add('is-active');
      filter.setAttribute('aria-selected', 'true');

      const category = filter.dataset.filter;

      cards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.classList.remove('is-hidden');
        } else {
          card.classList.add('is-hidden');
        }
      });
    });
  });
</script>
