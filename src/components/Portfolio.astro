---
import siteContent from '../data/siteContent.json';
const { portfolio } = siteContent;

const categories = ['Tous', ...new Set(portfolio.items.map(item => item.category))];
---

<section class="portfolio section" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="container">
    <div class="section__header">
      <h2 id="portfolio-heading" class="section__title">
        <span class="gradient-text">{portfolio.headline}</span>
      </h2>
    </div>

    <div class="portfolio__filters" role="tablist" aria-label="Filtrer les réalisations par catégorie">
      {categories.map((cat, i) => (
        <button
          class={`portfolio__filter ${i === 0 ? 'is-active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-filter={cat === 'Tous' ? 'all' : cat}
          type="button"
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="portfolio__grid" role="list">
      {portfolio.items.map((item) => (
        <article class="portfolio__card" data-category={item.category} role="listitem">
          <div class="portfolio__metric">
            <span class="portfolio__metric-value">{item.metric}</span>
            <span class="portfolio__metric-label">{item.metricLabel}</span>
          </div>
          <div class="portfolio__info">
            <span class="portfolio__category">{item.category}</span>
            <h3 class="portfolio__title">{item.title}</h3>
            <p class="portfolio__description">{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Filters */
  .portfolio__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    margin-bottom: var(--space-10);
  }

  .portfolio__filter {
    padding: var(--space-2) var(--space-5);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .portfolio__filter:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-light);
  }

  .portfolio__filter.is-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* Grid */
  .portfolio__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .portfolio__card {
    display: flex;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .portfolio__card.is-hidden {
    display: none;
  }

  .portfolio__card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .portfolio__metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 100px;
    padding: var(--space-4);
    background: var(--color-accent-glow);
    border-radius: var(--radius-md);
    text-align: center;
    flex-shrink: 0;
  }

  .portfolio__metric-value {
    font-size: var(--text-2xl);
    font-weight: var(--weight-extrabold);
    color: var(--color-accent-light);
    line-height: 1;
  }

  .portfolio__metric-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
    font-weight: var(--weight-medium);
  }

  .portfolio__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    justify-content: center;
  }

  .portfolio__category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-accent-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .portfolio__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
  }

  .portfolio__description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  @media (min-width: 640px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portfolio__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  const filters = document.querySelectorAll('.portfolio__filter');
  const cards = document.querySelectorAll('.portfolio__card');

  filters.forEach(filter => {
    filter.addEventListener('click', () => {
      // Update active state
      filters.forEach(f => {
        f.classList.remove('is-active');
        f.setAttribute('aria-selected', 'false');
      });
      filter.classList.add('is-active');
      filter.setAttribute('aria-selected', 'true');

      const category = filter.dataset.filter;

      cards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.classList.remove('is-hidden');
        } else {
          card.classList.add('is-hidden');
        }
      });
    });
  });
</script>
