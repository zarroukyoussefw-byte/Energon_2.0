---
import siteContent from '../data/siteContent.json';
const { portfolio } = siteContent;

const categories = ['Tous', ...new Set(portfolio.items.map(item => item.category))];
---

<section class="portfolio section" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="container">
    <div class="portfolio__header">
      <span class="portfolio__label">// Réalisations</span>
      <h2 id="portfolio-heading" class="portfolio__title">
        Des résultats, pas des <span class="portfolio__title-accent">promesses</span>
      </h2>
    </div>

    <div class="portfolio__filters" role="tablist" aria-label="Filtrer les réalisations par catégorie">
      {categories.map((cat, i) => (
        <button
          class={`portfolio__filter ${i === 0 ? 'is-active' : ''}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          data-filter={cat === 'Tous' ? 'all' : cat}
          type="button"
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="portfolio__grid" role="list">
      {portfolio.items.map((item, idx) => {
        const accent = item.accentColor || '#a855f7';
        return (
          <article
            class="portfolio__card"
            data-category={item.category}
            role="listitem"
            style={`--card-accent: ${accent}; --card-delay: ${idx * 0.08}s; --dots-color: ${accent}0d; --orb-color: ${accent}14; --zone-bg: ${accent}18;`}
          >
            <div class="portfolio__metric-zone">
              <div class="portfolio__orb" aria-hidden="true"></div>
              <span class="portfolio__badge">{item.category}</span>
              <div class="portfolio__metric">
                <span class="portfolio__metric-value">{item.metric}</span>
                <span class="portfolio__metric-label">{item.metricLabel}</span>
              </div>
            </div>
            <div class="portfolio__info">
              <h3 class="portfolio__card-title">{item.title}</h3>
              <p class="portfolio__card-desc">{item.description}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Header */
  .portfolio__header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .portfolio__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: #a855f7;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }

  .portfolio__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    color: var(--color-text);
  }

  .portfolio__title-accent {
    background: linear-gradient(135deg, #a855f7, #06b6d4);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Filters */
  .portfolio__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-bottom: var(--space-8);
  }

  .portfolio__filter {
    padding: 6px 14px;
    background: transparent;
    border: 1px solid rgba(168, 85, 247, 0.1);
    border-radius: 7px;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
    transition: transform var(--transition-fast);
    position: relative;
    z-index: 1;
  }

  .portfolio__filter::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    border: 1px solid rgba(168, 85, 247, 0.3);
    opacity: 0;
    transition: opacity var(--transition-fast);
    z-index: -1;
  }

  .portfolio__filter::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    opacity: 0;
    transition: opacity var(--transition-fast);
    z-index: -2;
  }

  .portfolio__filter:hover {
    color: #a855f7;
  }
  
  .portfolio__filter:hover::before {
    opacity: 1;
  }

  .portfolio__filter.is-active {
    color: #fff;
  }
  
  .portfolio__filter.is-active::after {
    opacity: 1;
  }

  /* Grid */
  .portfolio__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 560px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .portfolio__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .portfolio__card {
    border-radius: 14px;
    border: 1px solid rgba(168, 85, 247, 0.1);
    background: #0e0e1888;
    transition: transform var(--transition-base);
    animation: cardIn 0.5s ease both;
    animation-delay: var(--card-delay, 0s);
    position: relative;
    z-index: 1;
  }
  
  .portfolio__card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    border: 1px solid rgba(168, 85, 247, 0.25);
    background: #141422cc;
    opacity: 0;
    transition: opacity var(--transition-base);
    z-index: -1;
  }

  .portfolio__card.is-hidden {
    display: none;
  }

  .portfolio__card:hover {
    transform: translateY(-3px);
  }
  
  .portfolio__card:hover::before {
    opacity: 1;
  }

  .portfolio__card:hover .portfolio__metric-value {
    opacity: 1;
  }

  .portfolio__card:hover .portfolio__metric-label {
    opacity: 0.7;
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Metric zone (top) */
  .portfolio__metric-zone {
    position: relative;
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    overflow: hidden;
    background:
      radial-gradient(var(--dots-color) 1px, transparent 1px),
      linear-gradient(135deg, var(--zone-bg) 0%, #0e0e18 100%);
    background-size: 16px 16px, 100% 100%;
    border-top-left-radius: inherit;
    border-top-right-radius: inherit;
  }

  /* Orb glow */
  .portfolio__orb {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--orb-color) 0%, transparent 70%);
    filter: blur(20px);
    pointer-events: none;
  }

  .portfolio__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 13%, transparent);
    border-radius: 4px;
    padding: 3px 7px;
    line-height: 1;
    z-index: 1;
  }

  .portfolio__metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    z-index: 1;
  }

  .portfolio__metric-value {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: var(--weight-bold);
    color: var(--card-accent);
    line-height: 1;
    opacity: 0.7;
    transition: opacity var(--transition-base);
  }

  .portfolio__metric-label {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
    opacity: 0.5;
    transition: opacity var(--transition-base);
  }

  /* Info zone (bottom) */
  .portfolio__info {
    padding: 16px 18px 20px;
  }

  .portfolio__card-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .portfolio__card-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
</style>

<script>
  const observer = new IntersectionObserver((entries, obs) => {
    if (entries[0].isIntersecting) {
      import('../scripts/portfolio').then(m => m.initPortfolio());
      obs.disconnect();
    }
  });
  const section = document.getElementById('portfolio');
  if (section) observer.observe(section);
</script>
