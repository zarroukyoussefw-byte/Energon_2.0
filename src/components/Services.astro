---
import siteContent from '../data/siteContent.json';
const { services } = siteContent;
---

<section class="services section animate-section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <div class="section__header">
      <h2 id="services-heading" class="section__title">
        <span class="gradient-text">{services.headline}</span>
      </h2>
      <p class="section__subtitle">{services.subheadline}</p>
    </div>

    <div class="services__grid">
      {services.items.map((service) => (
        <article class="services__card">
          <div class="services__emoji" aria-hidden="true">{service.emoji}</div>
          <h3 class="services__card-title">{service.title}</h3>
          <p class="services__card-description">{service.description}</p>
          {service.features && (
            <ul class="services__features" role="list">
              {service.features.map((feature) => (
                <li class="services__feature">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2 7l3.5 3.5L12 4" stroke="var(--color-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .services__card {
    position: relative;
    padding: var(--space-8);
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06), 0 1px 4px rgba(0, 0, 0, 0.04);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: 1;
  }
  .services__card::after {
    content: '';
    position: absolute;
    inset: -1px; /* To cover the border */
    border-radius: inherit;
    border: 1px solid var(--color-border-hover);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.14), 0 4px 12px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(168, 85, 247, 0.15);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    pointer-events: none;
    z-index: -1;
  }

  .services__card:hover {
    transform: translateY(-8px);
  }

  .services__card:hover::after {
    opacity: 1;
  }

  .services__emoji {
    font-size: 2rem;
    margin-bottom: var(--space-5);
    line-height: 1;
  }

  .services__card-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-3);
  }

  .services__card-description {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .services__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .services__feature {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-weight: var(--weight-medium);
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
