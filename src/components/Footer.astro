---
import siteContent from '../data/siteContent.json';
const { footer, site } = siteContent;

const currentYear = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label={`${site.name} — Retour à l'accueil`}>
          <svg class="footer__logo-icon" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect width="32" height="32" rx="8" fill="var(--color-accent)" />
            <path d="M8 22L16 10L24 22H8Z" fill="white" opacity="0.9" />
          </svg>
          <span>{site.name}</span>
        </a>
        <p class="footer__description">{footer.description}</p>

        <div class="footer__socials">
          {site.socials.linkedin && (
            <a href={site.socials.linkedin} class="footer__social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
          {site.socials.instagram && (
            <a href={site.socials.instagram} class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
              </svg>
            </a>
          )}
          {site.socials.twitter && (
            <a href={site.socials.twitter} class="footer__social-link" aria-label="X (Twitter)" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M4 4l6.5 8L4 20h2l5.5-6.8L16 20h4l-6.8-8.5L20 4h-2l-5.2 6.3L9 4H4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          )}
        </div>
      </div>

      <div class="footer__links-group">
        <h3 class="footer__heading">Navigation</h3>
        <ul class="footer__links" role="list">
          {footer.links.map((link) => (
            <li><a href={link.href} class="footer__link">{link.text}</a></li>
          ))}
          <li><a href="/services/landing-page" class="footer__link">Création Landing Page IA</a></li>
        </ul>
      </div>

      <div class="footer__links-group">
        <h3 class="footer__heading">Légal</h3>
        <ul class="footer__links" role="list">
          {footer.legal.map((link) => (
            <li><a href={link.href} class="footer__link">{link.text}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__links-group">
        <h3 class="footer__heading">Contact</h3>
        <ul class="footer__links" role="list">
          <li>
            <a href={`tel:${site.contact.phone}`} class="footer__link">{site.contact.phone}</a>
          </li>
          <li>
            <a href={`mailto:${site.contact.email}`} class="footer__link">{site.contact.email}</a>
          </li>
          <li>
            <span class="footer__address">{site.contact.address.city}, {site.contact.address.postalCode} Tarn</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">
        © {currentYear} {site.name}. Tous droits réservés.
      </p>
      <a href="#hero" class="footer__back-top" aria-label="Retour en haut de page">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 13V3M4 7l4-4 4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-8);
    background: var(--color-bg-elevated);
  }

  .footer__grid {
    display: grid;
    gap: var(--space-10);
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
    color: var(--color-text);
    text-decoration: none;
  }

  .footer__logo:hover {
    color: var(--color-text);
  }

  .footer__description {
    margin-top: var(--space-4);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    max-width: 300px;
    line-height: var(--leading-relaxed);
  }

  .footer__socials {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    position: relative;
    z-index: 1;
  }

  .footer__social-link::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: var(--color-accent-glow);
    border: 1px solid var(--color-accent);
    opacity: 0;
    transition: opacity var(--transition-fast);
    z-index: -1;
  }

  .footer__social-link:hover {
    color: var(--color-accent-light);
  }
  
  .footer__social-link:hover::after {
    opacity: 1;
  }

  .footer__heading {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .footer__link:hover {
    color: var(--color-accent-light);
  }

  .footer__address {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .footer__copyright {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .footer__back-top {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: transform var(--transition-fast);
    position: relative;
    z-index: 1;
  }

  .footer__back-top::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    border: 1px solid var(--color-accent);
    opacity: 0;
    transition: opacity var(--transition-fast);
    z-index: -1;
  }

  .footer__back-top:hover {
    color: var(--color-accent-light);
    transform: translateY(-2px);
  }

  .footer__back-top:hover::after {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }
</style>
