---
import siteContent from '../data/siteContent.json';
const { cta } = siteContent;
---

<section class="cta-section" id="contact" aria-labelledby="cta-heading">
  <div class="cta__bg" aria-hidden="true">
    <div class="cta__glow cta__glow--1"></div>
    <div class="cta__glow cta__glow--2"></div>
  </div>

  <div class="container cta__content">
    <h2 id="cta-heading" class="cta__title">
      <span class="gradient-text">{cta.headline}</span>
    </h2>
    <p class="cta__description">{cta.description}</p>

    <form id="contact-form" class="cta__form" novalidate>
      <div class="cta__form-row">
        <div class="cta__field">
          <label for="contact-name" class="cta__label">Nom complet</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            autocomplete="name"
            placeholder="Jean Dupont"
            class="cta__input"
          />
        </div>
        <div class="cta__field">
          <label for="contact-email" class="cta__label">Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            autocomplete="email"
            placeholder="jean@exemple.fr"
            class="cta__input"
          />
        </div>
      </div>

      <div class="cta__field">
        <label for="contact-phone" class="cta__label">Téléphone</label>
        <input
          type="tel"
          id="contact-phone"
          name="phone"
          autocomplete="tel"
          placeholder="06 12 34 56 78"
          class="cta__input"
        />
      </div>

      <div class="cta__field">
        <label for="contact-message" class="cta__label">Message</label>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="4"
          placeholder="Décrivez votre projet en quelques lignes…"
          class="cta__input cta__textarea"
        ></textarea>
      </div>

      <div class="cta__consent">
        <label class="cta__consent-label">
          <input type="checkbox" id="contact-consent" name="consent" required class="cta__checkbox" />
          <span>J'accepte que mes données soient utilisées par ENERGON pour traiter ma demande de contact. Elles ne seront pas transmises à des tiers et seront supprimées sous 3 ans. <a href="/politique-confidentialite" class="cta__consent-link">Politique de confidentialité</a></span>
        </label>
      </div>

      <button type="submit" class="btn btn--primary btn--large cta__submit" id="contact-submit">
        Envoyer le message
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div id="contact-feedback" class="cta__feedback" role="status" aria-live="polite"></div>
    </form>

    <div class="cta__alt">
      <span class="cta__alt-label">Ou contactez-moi directement</span>
      <div class="cta__actions">
        <a href={cta.button.href} class="btn btn--secondary">
          {cta.button.text}
        </a>
        {cta.phone && (
          <a href={cta.phone.href} class="btn btn--secondary">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M14.5 11.2v1.8a1.2 1.2 0 01-1.3 1.2A11.9 11.9 0 011.8 2.8 1.2 1.2 0 013 1.5h1.8a1.2 1.2 0 011.2 1 7.6 7.6 0 00.4 1.7 1.2 1.2 0 01-.3 1.3l-.8.8a9.6 9.6 0 004.4 4.4l.8-.8a1.2 1.2 0 011.3-.3 7.6 7.6 0 001.7.4 1.2 1.2 0 011 1.2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {cta.phone.text}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    padding-block: var(--space-20);
    overflow: hidden;
    text-align: center;
  }

  .cta__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .cta__glow--1 {
    top: -30%;
    left: 20%;
    width: 400px;
    height: 400px;
    background: var(--color-accent);
    opacity: 0.08;
  }

  .cta__glow--2 {
    bottom: -30%;
    right: 20%;
    width: 300px;
    height: 300px;
    background: var(--color-success);
    opacity: 0.06;
  }

  .cta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .cta__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    max-width: 700px;
  }

  .cta__description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 500px;
    line-height: var(--leading-relaxed);
  }

  /* Form */
  .cta__form {
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-4);
    text-align: left;
  }

  .cta__form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 560px) {
    .cta__form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .cta__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cta__label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
  }

  .cta__input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
  }

  .cta__input::placeholder {
    color: var(--color-text-muted);
  }

  .cta__input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-glow);
  }

  .cta__textarea {
    resize: vertical;
    min-height: 100px;
    line-height: var(--leading-normal);
  }

  .cta__submit {
    align-self: center;
    margin-top: var(--space-2);
    min-width: 220px;
  }

  .cta__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  /* Consent */
  .cta__consent {
    margin-top: var(--space-2);
  }

  .cta__consent-label {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
    cursor: pointer;
  }

  .cta__checkbox {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 2px;
    accent-color: var(--color-accent);
    cursor: pointer;
  }

  .cta__consent-link {
    color: var(--color-accent-light);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cta__consent-link:hover {
    color: var(--color-accent);
  }

  /* Feedback */
  .cta__feedback {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-align: center;
    min-height: 1.5em;
  }

  .cta__feedback.is-success {
    color: #34d399;
  }

  .cta__feedback.is-error {
    color: #f87171;
  }

  /* Alt contact */
  .cta__alt {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta__alt-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  @media (min-width: 768px) {
    .cta-section {
      padding-block: var(--space-32);
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries, obs) => {
    if (entries[0].isIntersecting) {
      import('../scripts/cta').then(m => m.initCTA());
      obs.disconnect();
    }
  });
  const section = document.getElementById('contact');
  if (section) observer.observe(section);
</script>
