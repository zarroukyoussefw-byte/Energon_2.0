---
import siteContent from '../data/siteContent.json';
const { navigation, site } = siteContent;
---

<header class="header" id="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="ENERGON Solutions Digitales — Retour à l'accueil">
      <img src="/images/logo.svg" alt="ENERGON Solutions Digitales" width="250" height="56" />
    </a>

    <nav class="header__nav" id="main-nav" aria-label="Navigation principale">
      <ul class="header__nav-list" id="nav-list" role="list">
        {navigation.map((item) => (
          <li class="header__nav-item">
            <a href={item.href} class="header__nav-link">{item.text}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__actions">
      <a href="#contact" class="btn btn--primary header__cta">Contact</a>
      <button
        class="header__hamburger"
        id="hamburger-btn"
        type="button"
        aria-expanded="false"
        aria-controls="nav-list"
        aria-label="Ouvrir le menu de navigation"
      >
        <span class="header__hamburger-line" aria-hidden="true"></span>
        <span class="header__hamburger-line" aria-hidden="true"></span>
        <span class="header__hamburger-line" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<script src="../scripts/header.ts"></script>
